# ===========================================================================
# Smart Bet - Environment Variables
# ===========================================================================
# Copy this file to .env.local and fill the real values.
# NEVER commit .env.local to version control.
# ===========================================================================

# --- Supabase (client + server) ---------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Auth: em Authentication → Providers → Email, desative confirmação de e-mail
# para login imediato após o registo (fluxo alinhado à app; boas-vindas via Resend depois).

# --- Supabase (server only, NEVER expose to the browser) --------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
